@using BazaarCompanionWeb.Dtos
@using BazaarCompanionWeb.Utilities
@using Microsoft.AspNetCore.Components

<div class="flex flex-col gap-4">
    <!-- Trending Products -->
    <div class="rounded-xl border border-slate-700/50 bg-slate-900/60 shadow-xl backdrop-blur-xl p-4">
        <h3 class="text-lg font-bold text-white flex items-center gap-2 mb-4">
            <i class="ph ph-trend-up text-green-400"></i>
            Trending Products
        </h3>

        @if (!TrendingProducts.Any())
        {
            <div class="flex flex-col items-center justify-center py-12 text-slate-500">
                <i class="ph ph-chart-line text-4xl mb-2"></i>
                <p class="text-sm">No trend data available</p>
            </div>
        }
        else
        {
            <div class="space-y-2">
                @foreach (var trend in TrendingProducts)
                {
                    var trendColor = trend.TrendDirection switch
                    {
                        "Bullish" => "#78F86A",
                        "Bearish" => "#EF4444",
                        "Volatile" => "#F9AD35",
                        _ => "#808080"
                    };

                    <div class="flex items-center justify-between p-2 rounded-lg border border-slate-700/50 bg-slate-800/40 hover:bg-slate-800/60 transition-colors">
                        <div class="flex items-center gap-3 flex-1 min-w-0">
                            <div class="flex-shrink-0">
                                <div class="w-2 h-2 rounded-full" style="background-color: @trendColor;"></div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-slate-200 truncate">@trend.ProductName</p>
                                <p class="text-xs text-slate-500">@trend.TrendDirection</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 text-xs">
                            <div class="text-right">
                                <p class="text-slate-400">6h</p>
                                <p class="font-mono" style="color: @(trend.PriceChange6h >= 0 ? "#78F86A" : "#EF4444")">
                                    @(trend.PriceChange6h >= 0 ? "+" : "")@trend.PriceChange6h.ToString("P2")
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="text-slate-400">24h</p>
                                <p class="font-mono" style="color: @(trend.PriceChange24h >= 0 ? "#78F86A" : "#EF4444")">
                                    @(trend.PriceChange24h >= 0 ? "+" : "")@trend.PriceChange24h.ToString("P2")
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="text-slate-400">7d</p>
                                <p class="font-mono" style="color: @(trend.PriceChange7d >= 0 ? "#78F86A" : "#EF4444")">
                                    @(trend.PriceChange7d >= 0 ? "+" : "")@trend.PriceChange7d.ToString("P2")
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

@code {
    [Parameter] public List<ProductTrend> TrendingProducts { get; set; } = new();
}
