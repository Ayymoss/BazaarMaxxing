@*
    Inline error notice. Use when a non-critical async load failed and we want to tell the
    user rather than render a blank panel. Optional retry button.
*@

<div class="flex items-start gap-3 rounded-lg border border-amber-900/40 bg-amber-950/30 px-3 py-2.5">
    <i class="ph ph-warning-circle text-amber-400 text-base mt-0.5"></i>
    <div class="flex-1 min-w-0">
        <p class="text-xs text-amber-200">@Message</p>
        @if (Detail is not null)
        {
            <p class="text-[10px] text-amber-400/70 mt-0.5">@Detail</p>
        }
    </div>
    @if (OnRetry.HasDelegate)
    {
        <button @onclick="OnRetry"
                class="text-[10px] font-medium text-amber-300 hover:text-amber-200 px-2 py-1 rounded border border-amber-800/60 hover:bg-amber-900/30 transition-colors"
                aria-label="Retry loading">
            Retry
        </button>
    }
</div>

@code {
    [Parameter] public required string Message { get; set; }
    [Parameter] public string? Detail { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }
}
